import { createHash } from "crypto"

const URL = "https://mmvkcrcbrqfuwpcprqxs.supabase.co"
const KEY = "eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6Im1tdmtjcmNicnFmdXdwY3BycXhzIiwicm9sZSI6InNlcnZpY2Vfcm9sZSIsImlhdCI6MTc3OTQ4Mzk2NiwiZXhwIjoyMDk1MDU5OTY2fQ.-ilqNDAmb1MHqgy4dOpq4NtdZruQ_PNMTijbfpfXfkQ"
const H = { "Content-Type": "application/json", apikey: KEY, Authorization: `Bearer ${KEY}` }

const uuid = (s) => {
  const h = createHash("md5").update(s).digest("hex")
  return `${h.slice(0, 8)}-${h.slice(8, 12)}-4${h.slice(13, 16)}-a${h.slice(17, 20)}-${h.slice(20, 32)}`
}
const sleep = (ms) => new Promise((r) => setTimeout(r, ms))

async function insert(table, body) {
  const r = await fetch(`${URL}/rest/v1/${table}`, {
    method: "POST",
    headers: { ...H, Prefer: "resolution=merge-duplicates" },
    body: JSON.stringify(body),
  })
  const ct = r.headers.get("content-type") || ""
  const t = ct.includes("json") ? JSON.stringify(await r.json()).slice(0, 100) : (await r.text()).slice(0, 100)
  return { ok: r.ok, status: r.status, text: t }
}

