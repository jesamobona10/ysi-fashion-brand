    { order_number: "YSI-2026-006", customer_email: "amara.okafor@example.com", status: "confirmed", subtotal: 890000, shipping: 0, total: 890000, payment_method: "paystack", payment_status: "paid", city: "Lagos", state: "Lagos", country: "Nigeria", items: [{ product_slug: "cashmere-overcoat", name: "The Cashmere Overcoat", quantity: 1, price: 890000, size: "42", color: "Charcoal" }] },
    { order_number: "YSI-2026-007", customer_email: "michael.adewale@example.com", status: "tailoring", subtotal: 750000, shipping: 0, total: 750000, payment_method: "bank-transfer", payment_status: "paid", city: "Lagos", state: "Lagos", country: "Nigeria", items: [{ product_slug: "power-suit", name: "The Power Suit", quantity: 1, price: 750000, size: "L", color: "Navy" }] },
    { order_number: "YSI-2026-008", customer_email: "sarah.johnson@example.com", status: "pending", subtotal: 1200000, shipping: 0, total: 1200000, payment_method: "paystack", payment_status: "pending", city: "Abuja", state: "FCT", country: "Nigeria", items: [{ product_slug: "bridal-masterpiece", name: "The Bridal Masterpiece", quantity: 1, price: 1200000, size: "S", color: "Pure White" }] },
  ]

  for (const order of orders) {
    const orderId = uuid(order.order_number)
    const cid = customerIds[order.customer_email]
    if (!cid) { console.log(`  ✗ ${order.order_number}: customer not found`); continue }

    const { customer_email, items, ...orderData } = order
    const r = await insert("orders", { id: orderId, customer_id: cid, ...orderData })
    console.log(`  ${r.ok ? "✓" : "✗"} ${order.order_number} (${r.status})${!r.ok ? " " + r.text : ""}`)

    if (r.ok && items) {
      for (const item of items) {
        const { product_slug, ...itemData } = item
        const pid = productIds[product_slug]
        await insert("order_items", { id: uuid(`${order.order_number}-${product_slug}`), order_id: orderId, product_id: pid, ...itemData })
      }
      await insert("order_timeline", { id: uuid(`${order.order_number}-created`), order_id: orderId, status: orderData.status, note: "Order placed" })
    }
  }

  await sleep(500)

  console.log("\nSeeding inventory logs...")
  const inventoryLogs = [
    { slug: "executive-tailored-blazer", type: "restock", quantity: 10, previous_stock: 5, new_stock: 15 },
    { slug: "empress-evening-gown", type: "restock", quantity: 8, previous_stock: 0, new_stock: 8 },
    { slug: "bridal-masterpiece", type: "restock", quantity: 3, previous_stock: 0, new_stock: 3 },
    { slug: "leather-crossbody", type: "restock", quantity: 20, previous_stock: 0, new_stock: 20 },
    { slug: "linen-resort-shirt", type: "restock", quantity: 30, previous_stock: 0, new_stock: 30 },
  ]

  for (const log of inventoryLogs) {
    const pid = productIds[log.slug]
    if (!pid) { console.log(`  ✗ product ${log.slug} not found`); continue }
    const { slug, ...logData } = log
    const r = await insert("inventory_logs", { id: uuid(`inv-${log.slug}`), product_id: pid, ...logData })
    console.log(`  ${r.ok ? "✓" : "✗"} ${log.slug} (${r.status})`)
  }

  console.log("\n=== Verification ===")
  for (const table of ["products", "customers", "orders", "order_items", "order_timeline", "inventory_logs"]) {
    const r = await fetch(`${URL}/rest/v1/${table}?limit=100`, { headers: H })
    if (r.ok) {
      const d = await r.json()
      console.log(`  ${table}: ${d.length} rows`)
    } else {
      const t = await r.text()
      console.log(`  ${table}: ERROR ${r.status} ${t.slice(0, 100)}`)
    }
  }
}

main().catch(console.error)