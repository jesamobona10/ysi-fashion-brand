    { order_number: "YSI-2026-001", customer_email: "amara.okafor@example.com", status: "delivered", subtotal: 1130000, shipping: 0, total: 1130000, payment_method: "paystack", payment_status: "paid", street: "12 Admiralty Way", city: "Lekki", state: "Lagos", country: "Nigeria", items: [{ product_slug: "executive-tailored-blazer", name: "The Executive Tailored Blazer", quantity: 1, price: 450000, size: "42", color: "Jet Black" }, { product_slug: "power-suit", name: "The Power Suit", quantity: 1, price: 750000, size: "M", color: "Jet Black" }] },
