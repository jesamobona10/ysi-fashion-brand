async function main() {
  console.log("=== YSI Seed Data Migration ===\n")

  console.log("Seeding products...")
  const productIds = {}
  for (const p of productsData) {
    const id = uuid(p.slug)
    productIds[p.slug] = id
    const r = await insert("products", { id, ...p })
    console.log(`  ${r.ok ? "✓" : "✗"} ${p.name} (${r.status})${!r.ok ? " " + r.text : ""}`)
  }

  await sleep(500)

  console.log("\nSeeding customers...")
  const customerIds = {}
  for (const c of customersData) {
    const id = uuid(c.email)
    customerIds[c.email] = id
    const r = await insert("customers", { id, ...c })
    console.log(`  ${r.ok ? "✓" : "✗"} ${c.name} (${r.status})${!r.ok ? " " + r.text : ""}`)
  }

  await sleep(500)

  console.log("\nSeeding orders...")
