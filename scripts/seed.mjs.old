    { order_number: "YSI-2026-003", customer_email: "david.kalu@example.com", status: "shipped", subtotal: 370000, shipping: 15000, total: 385000, payment_method: "paystack", payment_status: "paid", city: "Abuja", state: "FCT", country: "Nigeria", items: [{ product_slug: "signature-tailored-trousers", name: "The Signature Tailored Trousers", quantity: 2, price: 185000, size: "34", color: "Navy" }] },
    { order_number: "YSI-2026-004", customer_email: "tunde.adebayo@example.com", status: "quality-check", subtotal: 380000, shipping: 0, total: 380000, payment_method: "paystack", payment_status: "paid", city: "Lagos", state: "Lagos", country: "Nigeria", items: [{ product_slug: "aso-oke-blazer", name: "The Aso Oke Blazer", quantity: 1, price: 380000, size: "42", color: "Emerald" }] },
